            color:#856404;
            padding:4px 10px;
            border-radius:12px;
            font-weight:600;
            font-size:12px;
            display:inline-block;
		"&gt;
			⏳ Pendiente
		&lt;/span&gt;';
		break;
	
	case "APROBADO":
		$value = '
		&lt;span style="
			background-color:#d4edda;
            color:#155724;
            padding:4px 10px;
            border-radius:12px;
            font-weight:600;
            font-size:12px;
            display:inline-block;
		"&gt;
			✅ Aprobado
        &lt;/span&gt;';
        break;
	
	case "RECHAZADO":
		$value = '
		&lt;span style="
            background-color:#f8d7da;
            color:#721c24;
            padding:4px 10px;
            border-radius:12px;
            font-weight:600;
            font-size:12px;
            display:inline-block;
        "&gt;
			❌ Rechazado
        &lt;/span&gt;';
        break;
}</m_strCustomExpr>
