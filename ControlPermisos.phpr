					<m_strName>EVENT_BEFORESHOW_ADD</m_strName>
					<m_strEventCode>/*****************************************************************
 * EVENTO: Before Display (ADD)
 * MÓDULO: Solicitudes de Vacaciones
 * DESCRIPCIÓN:
 *  - Oculta campos técnicos y de auditoría
 *  - Evita que el usuario modifique datos de sistema
 *  - Estos valores se asignan automáticamente en backend
 *****************************************************************/

/*==============================================================
=            CAMPOS DE CONTROL DE ESTADO                       =
==============================================================*/

// Estado de la solicitud (se inicializa como "PENDIENTE" en backend)
$pageObject-&gt;hideItem("add_estado");//oculta el campo estado

// Fecha de creación del registro (asignada automáticamente)
$pageObject-&gt;hideItem("add_fecha_creacion");//oculta el campo fecha_creacion

// Usuario que crea la solicitud (usuario logueado)
$pageObject-&gt;hideItem("add_usuario_creador");//oculta el campo usuario_creador

// ID primario del registro (se genera automáticamente)
$pageObject-&gt;hideItem("add_id");//oculta el campo id
// ID interno del funcionario (se obtiene por la cédula)
$pageObject-&gt;hideItem("add_id_funcionario");//oculta el campo id_funcionario

// Fecha de última actualización (uso interno del sistema)
$pageObject-&gt;hideItem("add_fecha_actualizacion");//oculta el campo fecha_actualizacion

// Usuario que realizó la última actualización
$pageObject-&gt;hideItem("add_usuario_actualizacion");//oculta el campo usuario_actualizacion


$pageObject-&gt;hideItem("add_dependencia_id");


// Obtener datos del usuario logueado en PHPRunner
$currentUser = Security::currentUserData();

// ID del usuario logueado (tabla users de PHPRunner)
$userPersonal = $currentUser["usu_personal"];

// Obtener Dependencia y datos de la persona logueada.
$sqlDependencia = "SELECT d.dep_descripcion || ' - ' || d.dep_descripcion_corta AS descripcion_dependencia,
																p.per_ci AS persona_ci,
																d.dep_cod,
																p.per_nombre || ' - ' || p.per_apellido AS nombre_completo,
																p.per_cod
												FROM personales p
													JOIN dependencias d ON d.dep_cod = p.dependencias_dep_cod
												WHERE p.per_cod = $userPersonal";
$resultDependencia = CustomQuery($sqlDependencia);
$dataDependencia = db_fetch_array($resultDependencia);
$pageObject-&gt;setProxyValue("dep_cod", $dataDependencia["dep_cod"]);
$pageObject-&gt;setProxyValue("descripcion_dependencia", $dataDependencia["descripcion_dependencia"]);
$pageObject-&gt;setProxyValue("persona_ci", $dataDependencia["persona_ci"]);
$pageObject-&gt;setProxyValue("nombre_completo", $dataDependencia["nombre_completo"]);
$pageObject-&gt;setProxyValue("per_cod", $dataDependencia["per_cod"]);


</m_strEventCode>
					<m_strEventID>EVENT_BEFORESHOW_ADD</m_strEventID>
					<m_strWidgetID></m_strWidgetID>
					<sub></sub>
					<m_caption>
						<text></text>
						<nameType>Text</nameType>
					</m_caption>
					<m_strDotNetLanguage>cs</m_strDotNetLanguage>
				</v>
				<v>
					<m_isRunTime>1</m_isRunTime>
					<m_strPage>Add page</m_strPage>
					<m_strName>EVENT_JS_ONLOAD</m_strName>
					<m_strEventCode>/*****************************************************************
 * EVENTO: JavaScript OnLoad
 * MÓDULO: Solicitudes de Vacaciones
 * DESCRIPCIÓN:
 *  - Obtiene datos del funcionario a partir de la cédula
 *  - Autocompleta campos del formulario
 *  - Calcula automáticamente los días de vacaciones solicitados
 *****************************************************************/


/*==============================================================
=            CONTROLES DEL FUNCIONARIO                         =
==============================================================*/
// Controles del formulario relacionados al funcionario
var id_funcionario = Runner.getControl(pageid, 'id_funcionario');
var per_ci = Runner.getControl(pageid, 'per_ci');
var nombre_completo = Runner.getControl(pageid, 'nombre_completo');



var dependencia_id = Runner.getControl(pageid, 'dependencia_id');
dependencia_id.setValue(pageObj.proxy.dep_cod);

var descripcion_dependencia = Runner.getControl(pageid, 'descripcion_dependencia');
descripcion_dependencia.setValue(pageObj.proxy.descripcion_dependencia);
descripcion_dependencia.makeReadonly();






per_ci.setValue(pageObj.proxy.persona_ci);
per_ci.makeReadonly();

nombre_completo.setValue(pageObj.proxy.nombre_completo);
nombre_completo.makeReadonly();

id_funcionario.setValue(pageObj.proxy.per_cod);

/*==============================================================
=            BÚSQUEDA DE FUNCIONARIO POR CÉDULA                =
==============================================================*/
/**
 * Cuando el usuario ingresa o cambia la cédula:
 *  - Se consulta al sistema externo (sii_ci_new.php)
 *  - Se autocompletan los datos del funcionario
 *  - Se bloquean los campos para evitar modificaciones
 */
/*
per_ci.on("change", function(e) {
	
	$.get("sii_ci_new.php", { ci: this.getValue() })
		.done(function(data) {
			
			// Validar que el servicio haya devuelto datos válidos.
			if (data !== 'Ha sucedido el siguiente error: Persona no encontrada') {
				
				// Separar la respuesta en partes
				// Formato esperado: id:nombre:apellido:ci:origen
				var myarr = data.trim().split(":");
			
				if (myarr.length &gt; 0) {
					id_funcionario.setValue(myarr[0]);
					nombre_completo.setValue(myarr[1] + ' ' + myarr[2]);
					per_ci.setValue(myarr[3]);
				
					// Bloquear campos para evitar edición manual.
					per_ci.makeReadonly();
					nombre_completo.makeReadonly();
				} else {
					alert('La respuesta no tiene el formato esperado.');
				}
			} else {
				alert('No funciona el sistema de identificacion, cargue manualmente');
			}
	});
});
*/


/*==============================================================
=            CONTROLES DE FECHAS Y DÍAS DE VACACIONES           =
==============================================================*/
// Controles de fechas y total de días
var fecha_desde = Runner.getControl(pageid, "fecha_desde");
var fecha_hasta = Runner.getControl(pageid, "fecha_hasta");
var total_dias_habiles = Runner.getControl(pageid, "total_dias_habiles");

/*==============================================================
=            CÁLCULO DE DÍAS DE VACACIONES                      =
==============================================================*/
/**
 * Calcula la cantidad total de días entre dos fechas.
 * Incluye ambos días (fecha desde y fecha hasta).
 * NOTA: Actualmente calcula días corridos, no excluye fines de semana.
 */
function calcularDiasVacaciones() {
	var inicioStr = fecha_desde.getValue();
	var finStr = fecha_hasta.getValue();
	
	// Si falta alguna fecha, limpiar el campo
	if (!inicioStr || !finStr) {
		total_dias_habiles.setValue("");
		return;
	}
	
	var fechaDesde = new Date(inicioStr);
	var fechaHasta = new Date(finStr);
	
	// Validar que las fechas sean correctas.
	if (isNaN(fechaDesde) || isNaN(fechaHasta)) {
		total_dias_habiles.setValue("");
		return;
	}
	
	// Validar que la fecha hasta no sea menor que la fecha desde.
	if (fechaHasta &lt; fechaDesde) {
		total_dias_habiles.setValue("");
		return;
	}
	
	// Diferencia en milisegundos
	var diffTime = fechaHasta.getTime() - fechaDesde.getTime();
	
	// Convertir a días
	var diffDias = Math.floor(diffTime / (1000 * 60 * 60 * 24)) + 1;
	
	// Asignar resultado al campo
	total_dias_habiles.setValue(diffDias);
}


/*==============================================================
=            EVENTOS CHANGE PARA LAS FECHAS                    =
==============================================================*/
// Recalcular días cuando cambia la fecha de inicio
fecha_desde.on("change", function () {
    calcularDiasVacaciones();
});

// Recalcular días cuando cambia la fecha de fin
fecha_hasta.on("change", function () {
    calcularDiasVacaciones();
});

</m_strEventCode>
