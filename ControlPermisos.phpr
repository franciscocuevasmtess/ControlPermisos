			<m_strSQL>SELECT
pf.id,
pf.id_funcionario,
p.per_nombre,
p.per_apellido,
p.per_nombre || ' ' || p.per_apellido AS nombre_completo,
p.per_ci,
pf.tipo_vinculacion,
pf.dependencia_id,
pf.fecha_desde,
pf.hora_desde,
pf.fecha_hasta,
pf.hora_hasta,
pf.motivo_id,
pf.comision_servicios,
pf.comision_servicios_descripcion,
pf.observacion,
pf.estado,
pf.archivo_adjunto,
'' AS email_jefe,
'' AS descripcion_dependencia,
'' AS descripcion_tipo_vinculacion,
pf.solicitado_por,
pf.fecha_solicitud,
'' AS email_jefe_id,
pf.resultado_decision,
pf.horas_compensar,
'' AS nombre_completo_edit,
'' AS descripcion_dependencia_edit,
pf.rrhh_resultado_decision
FROM rrhh_permisos.permisos_funcionarios AS pf
LEFT OUTER JOIN "public".personales AS p ON pf.id_funcionario = p.per_cod
</m_strSQL>
